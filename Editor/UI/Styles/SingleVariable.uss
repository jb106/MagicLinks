.singleVariableElement {
    margin-right: 5px;
    -unity-font-definition: url("project://database/Assets/MagicLinks/Editor/Fonts/Helvetica/Helvetica.ttf?fileID=12800000&guid=b4e6e011032fcf94e999ee13a92ce425&type=3#Helvetica");
}

.minSize {
    flex-grow: 1;
}

/* Truncate long variable names with an ellipsis instead of pushing the layout */
.variableName {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}
